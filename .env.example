# ==========================================
# OdontoCix — Variables de Entorno
# ==========================================
# Copia este archivo a .env y completa los valores

# --- Laravel API (api/.env) ---
APP_NAME=OdontoCix
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=pgsql
# DB_URL — completar con URL de conexión de Neon (reemplazar usuario, password, host)
DB_URL="postgresql://user:password@host/dbname?sslmode=require"

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:8000

MAIL_MAILER=resend
MAIL_FROM_ADDRESS=noreply@odontocix.com
MAIL_FROM_NAME="${APP_NAME}"
# RESEND_API_KEY — obtener en https://resend.com
RESEND_API_KEY=

# RENIEC API — https://decolecta.gitbook.io/docs
RENIEC_API_URL=https://api.decolecta.com/v1/reniec/dni
RENIEC_API_TOKEN=

FRONTEND_URL=http://localhost:5173

# --- React Panel (apps/panel/.env) ---
VITE_API_URL=http://localhost:8000
