---
import Layout from '../layouts/Layout.astro'
---

<Layout>
  <main class="min-h-screen flex flex-col">
    <header class="flex items-center justify-between px-6 py-4 border-b">
      <span class="text-xl font-bold text-primary">OdontoCix</span>
      <nav class="space-x-4">
        <a href="/login" class="text-sm hover:underline">Iniciar sesión</a>
      </nav>
    </header>

    <section class="flex-1 flex flex-col items-center justify-center px-6 text-center space-y-6">
      <h1 class="text-5xl font-bold tracking-tight">Gestión Odontológica<br />Inteligente</h1>
      <p class="text-xl text-muted-foreground max-w-xl">
        Pacientes, citas, odontograma, presupuestos y caja en un solo lugar.
        Diseñado para clínicas dentales de Latinoamérica.
      </p>
      <div class="flex gap-4">
        <a href="/registro" class="inline-flex h-10 items-center justify-center rounded-md bg-primary px-8 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90">
          Crear mi clínica
        </a>
        <a href="/login" class="inline-flex h-10 items-center justify-center rounded-md border px-8 text-sm font-medium transition-colors hover:bg-muted">
          Iniciar sesión
        </a>
      </div>
    </section>

    <footer class="px-6 py-4 border-t text-center text-sm text-muted-foreground">
      &copy; {new Date().getFullYear()} OdontoCix
    </footer>
  </main>
</Layout>
