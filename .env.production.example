# ==========================================
# OdontoCix — Variables de Entorno (Producción)
# ==========================================
# Copia este archivo a .env en Render Dashboard y completa los valores

# --- Laravel API ---
APP_NAME=OdontoCix
APP_ENV=production
APP_DEBUG=false
APP_URL=https://odontocix-api.onrender.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PE

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=pgsql
# IMPORTANTE: Reemplazar con tu URL de Neon PostgreSQL
DB_URL="postgresql://user:password@host/dbname?sslmode=require"

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

SANCTUM_STATEFUL_DOMAINS=odontocix.onrender.com,odontocix-api.onrender.com

MAIL_MAILER=resend
MAIL_FROM_ADDRESS=noreply@odontocix.com
MAIL_FROM_NAME="${APP_NAME}"

# Obtener API key en https://resend.com
RESEND_API_KEY=

# RENIEC API — https://decolecta.gitbook.io/docs
RENIEC_API_URL=https://api.decolecta.com/v1/reniec/dni
RENIEC_API_TOKEN=

FRONTEND_URL=https://odontocix.onrender.com

# Demo credentials (used by SuperAdminSeeder)
DEMO_TENANT_EMAIL=demo@odontocix.com
DEMO_TENANT_NAME="Clínica Demo"
DEMO_TENANT_RUC=12345678901
DEMO_TENANT_PHONE=999000000
DEMO_TENANT_ADDRESS="Av. Demostración 123"
DEMO_ADMIN_EMAIL=admin@odontocix.com
# IMPORTANTE: Cambiar en producción
DEMO_ADMIN_PASSWORD=admin123456

# Sanctum token expiration in minutes (7 days)
SANCTUM_TOKEN_EXPIRATION=10080

# --- React Panel ---
VITE_API_URL=https://odontocix-api.onrender.com
